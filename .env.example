# ── Server ─────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
# Set to true to enable hot-reload (development only)
DEBUG=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Dataset Paths ─────────────────────────────────────────────────────────────
# Absolute path to the project root. Defaults to the parent of /backend.
# Override if your datasets live on a different drive.
# REPO_ROOT=D:/miniproject

# ── TensorFlow / GPU ──────────────────────────────────────────────────────────
# Suppress oneDNN info noise on CPU
TF_ENABLE_ONEDNN_OPTS=0
# Suppress TF startup messages (0=all, 1=info, 2=warning, 3=error)
TF_CPP_MIN_LOG_LEVEL=2

# ── HuggingFace ───────────────────────────────────────────────────────────────
# HF_HOME=D:/huggingface_cache
